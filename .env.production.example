# =============================================================================
# Production environment for the Dockerized VPS deploy.
# Copy to `.env` on the server:  cp .env.production.example .env
# Then set APP_KEY, SERVER_NAME, the DB passwords, and your mail credentials.
# =============================================================================

APP_NAME="Spin The Wheel | Brightstar Computer Sdn Bhd"
APP_ENV=production
# Generate once:  docker compose run --rm app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false

# Public URL + the domain FrankenPHP/Caddy should obtain TLS for.
# SERVER_NAME must be the bare domain(s), space-separated, e.g. "spin.example.com".
# Use ":80" to serve plain HTTP (behind another proxy / for local testing).
APP_URL=https://spin.example.com
SERVER_NAME=spin.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Container-friendly logging (visible via `docker compose logs`).
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=warning

# Database — DB_HOST is the compose service name. DB_ROOT_PASSWORD is used only
# by the MySQL container / healthcheck.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=spinthewheel
DB_USERNAME=spinthewheel
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-root-strong

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Polling mode: broadcasts are logged (not sent to a websocket server), so no
# Reverb container is required. The queue worker still runs the failsafe
# spin-completion job. Set VITE_REVERB_ENABLED=false at build time (default).
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# Mail (OTP delivery) — set to your SMTP provider.
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# App defaults (also editable in the admin panel at runtime).
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
SPIN_LOCK_TIMEOUT_SECONDS=45

# Frontend build flags (baked at image build). Keep false for polling mode.
VITE_REVERB_ENABLED=false
